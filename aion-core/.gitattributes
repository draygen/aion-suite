# Normalize line endings: LF everywhere, regardless of OS or editor
* text=auto eol=lf

# Explicitly enforce LF for code and scripts
*.py   text eol=lf
*.sh   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
.gitattributes text eol=lf

# Binary — never touch line endings
*.png  binary
*.jpg  binary
*.mp3  binary
*.mp4  binary
*.wav  binary
