{
  "id": "aion-vast",
  "name": "Aion on Vast",
  "project": "aion",
  "target_type": "vast",
  "description": "Classic Aion deployment on a Vast.ai instance.",
  "defaults": {
    "instance_id": "",
    "ssh_host": "",
    "ssh_port": "",
    "repo_path": "C:\\aion"
  },
  "config_fields": [
    {
      "name": "instance_id",
      "label": "Vast Instance ID",
      "required": true,
      "placeholder": "12345678"
    },
    {
      "name": "ssh_host",
      "label": "SSH Host",
      "required": false,
      "placeholder": "ssh4.vast.ai"
    },
    {
      "name": "ssh_port",
      "label": "SSH Port",
      "required": false,
      "placeholder": "32455"
    },
    {
      "name": "repo_path",
      "label": "Repo Path",
      "required": true,
      "placeholder": "C:\\aion"
    }
  ],
  "action_fields": {
    "redeploy": [
      {
        "name": "ssh_host",
        "label": "SSH Host Override",
        "required": false,
        "placeholder": "Uses saved target value if blank"
      },
      {
        "name": "ssh_port",
        "label": "SSH Port Override",
        "required": false,
        "placeholder": "Uses saved target value if blank"
      }
    ]
  },
  "actions": {
    "sync": {},
    "connect": {},
    "start": {},
    "stop": {},
    "restart": {},
    "redeploy": {},
    "destroy": {}
  }
}
